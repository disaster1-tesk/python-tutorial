  {
    "id": "ex_net_003",
    "module": "networking",
    "title": "TCP 简单通信",
    "difficulty": "medium",
    "points": 15,
    "description": "实现简单的 TCP 服务器和客户端",
    "starter_code": "import socket\n\n# TCP 服务器\ndef start_server(port=9999):\n    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n    server.bind(('', port))\n    server.listen(1)\n    print(f'服务器监听端口 {port}')\n    \n    conn, addr = server.accept()\n    print(f'连接来自: {addr}')\n    \n    # 接收并回复\n    # 你的代码\n    \n    conn.close()\n    server.close()\n\n# TCP 客户端\ndef start_client(port=9999):\n    client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n    client.connect(('localhost', port))\n    \n    # 发送并接收\n    # 你的代码\n    \n    client.close()\n\nprint('请在两个终端分别运行服务器和客户端')",
    "solution": "import socket\n\n# TCP 服务器\ndef start_server(port=9999):\n    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)\n    server.bind(('', port))\n    server.listen(1)\n    print(f'服务器监听端口 {port}')\n    \n    conn, addr = server.accept()\n    print(f'连接来自: {addr}')\n    \n    # 接收数据\n    data = conn.recv(1024).decode()\n    print(f'收到: {data}')\n    \n    # 回复\n    conn.sendall('Hello from server!'.encode())\n    \n    conn.close()\n    server.close()\n\n# TCP 客户端\ndef start_client(port=9999):\n    client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n    client.connect(('localhost', port))\n    \n    # 发送数据\n    client.sendall('Hello from client!'.encode())\n    \n    # 接收回复\n    response = client.recv(1024).decode()\n    print(f'收到回复: {response}')\n    \n    client.close()\n\nprint('示例代码已定义')",
    "tags": [
      "TCP",
      "Socket"
    ]
  },
