    "id": "ex_mcp_protocol_005",
    "module": "mcp_protocol",
    "title": "MCP 架构模拟",
    "difficulty": "hard",
    "points": 20,
    "description": "模拟 MCP 的主机-客户端-服务器架构",
    "starter_code": "# 模拟 MCP 架构\nclass MCPHost:\n    pass\n\nclass MCPClient:\n    pass\n\nclass MCPServer:\n    pass",
    "solution": "class MCPServer:\n    \"\"\"MCP 服务器\"\"\"\n    def __init__(self, name):\n        self.name = name\n        self.tools = {}\n        print(f'服务器 {name} 启动')\n    \n    def register_tool(self, tool):\n        self.tools[tool['name']] = tool\n    \n    def list_tools(self):\n        return list(self.tools.values())\n    \n    def call_tool(self, name, args):\n        if name in self.tools:\n            # 简化：直接返回参数\n            return f'执行 {name}: {args}'\n        return '工具不存在'\n\nclass MCPClient:\n    \"\"\"MCP 客户端\"\"\"\n    def __init__(self, server):\n        self.server = server\n    \n    def list_tools(self):\n        return self.server.list_tools()\n    \n    def call_tool(self, name, args):\n        return self.server.call_tool(name, args)\n\nclass MCPHost:\n    \"\"\"MCP 主机\"\"\"\n    def __init__(self):\n        self.server = MCPServer('MyServer')\n        self.client = MCPClient(self.server)\n    \n    def process(self, request):\n        # 处理请求\n        print(f'处理请求: {request}')\n        result = self.client.call_tool('calculate', request)\n        return result\n\n# 测试\nhost = MCPHost()\nhost.server.register_tool({'name': 'calculate', 'description': '计算器'})\nprint(f'可用工具: {host.client.list_tools()}')\nresult = host.process({'expression': '2+3'})\nprint(f'结果: {result}')",
    "tags": [
      "MCP",
      "架构"
    ]
  },
  {
    "id": "ex_mcp_server_001",
    "module": "mcp_server",
    "title": "基础 MCP 服务器",
    "difficulty": "medium",
    "points": 15,
    "description": "创建一个简单的 MCP 服务器框架",
    "starter_code": "class MCPServer:\n    def __init__(self, name):\n        self.name = name\n        self.tools = {}\n    \n    def on_list_tools(self):\n        # 返回工具列表\n        pass\n    \n    def on_call_tool(self, name, args):\n        # 调用工具\n        pass\n    \n    def run(self):\n        print(f'{self.name} 运行中...')",
    "solution": "class SimpleMCPServer:\n    \"\"\"简单 MCP 服务器\"\"\"\n    def __init__(self, name='SimpleServer'):\n        self.name = name\n        self.tools = {}\n        self._register_default_tools()\n    \n    def _register_default_tools(self):\n        self.tools = {\n            'greet': self._greet,\n            'echo': self._echo,\n            'status': self._status\n        }\n    \n    def _greet(self, name='World'):\n        return f'Hello, {name}!'\n    \n    def _echo(self, message=''):\n        return f'ECHO: {message}'\n    \n    def _status(self):\n        return f'Server: {self.name}, Tools: {len(self.tools)}'\n    \n    def on_list_tools(self):\n        \"\"\"列出工具\"\"\"\n        return [\n            {'name': name, 'description': func.__doc__ or '无描述'}\n            for name, func in self.tools.items()\n        ]\n    \n    def on_call_tool(self, name, args):\n        \"\"\"调用工具\"\"\"\n        if name in self.tools:\n            try:\n                return self.tools[name](**args)\n            except Exception as e:\n                return f'错误: {str(e)}'\n        return f'工具不存在: {name}'\n    \n    def run(self):\n        print(f'🖥️  {self.name} 启动')\n        print(f'已注册 {len(self.tools)} 个工具')\n        print('工具列表:')\n        for tool in self.on_list_tools():\n            print(f'  - {tool[\"name\"]}: {tool[\"description\"]}')\n\n# 测试\nserver = SimpleMCPServer()\nserver.run()\nprint()\nprint('调用测试:')\nprint(server.on_call_tool('greet', {'name': 'Alice'}))\nprint(server.on_call_tool('echo', {'message': 'Test'}))\nprint(server.on_call_tool('status', {}))",
    "tags": [
      "MCP Server",
      "基础"
    ]
  },
  {
    "id": "ex_mcp_server_002",
    "module": "mcp_server",
    "title": "MCP 服务器工具注册",
    "difficulty": "medium",
    "points": 15,
    "description": "实现动态工具注册功能",
    "starter_code": "class ToolRegistry:\n    def __init__(self):\n        self.tools = {}\n    \n    def register(self, name, handler, description=''):\n        # 注册工具\n        pass\n    \n    def unregister(self, name):\n        # 注销工具\n        pass\n    \n    def list_tools(self):\n        # 列出工具\n        pass",
    "solution": "class ToolRegistry:\n    \"\"\"工具注册表\"\"\"\n    def __init__(self):\n        self.tools = {}\n    \n    def register(self, name, handler, description=''):\n        self.tools[name] = {\n            'handler': handler,\n            'description': description\n        }\n        print(f'✓ 注册工具: {name}')\n    \n    def unregister(self, name):\n        if name in self.tools:\n            del self.tools[name]\n            print(f'✓ 注销工具: {name}')\n        else:\n            print(f'工具不存在: {name}')\n    \n    def list_tools(self):\n        return [\n            {'name': name, 'description': info['description']}\n            for name, info in self.tools.items()\n        ]\n\n# 测试\nregistry = ToolRegistry()\n\n# 注册工具\ndef add(a, b):\n    '''计算两个数的和'''\n    return a + b\n\ndef multiply(a, b):\n    '''计算两个数的积'''\n    return a * b\n\ndef to_upper(text):\n    '''转换为大写'''\n    return text.upper()\n\nregistry.register('add', add, '计算两个数的和')\nregistry.register('multiply', multiply, '计算两个数的积')\nregistry.register('to_upper', to_upper, '文本转大写')\n\n# 列出工具\nprint()\nprint('工具列表:')\nfor tool in registry.list_tools():\n    print(f'  - {tool[\"name\"]}: {tool[\"description\"]}')\n\n# 注销工具\nprint()\nregistry.unregister('multiply')",
    "tags": [
      "MCP Server",
      "工具注册"
    ]
  },
