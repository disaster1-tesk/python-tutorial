      "测试"
    ]
  },
  {
    "id": "ex_unit_002",
    "module": "unit_testing",
    "title": "pytest 基础",
    "difficulty": "easy",
    "points": 10,
    "description": "使用 pytest 编写测试",
    "starter_code": "# pytest 测试示例\n\ndef is_prime(n):\n    \"\"\"判断是否为质数\"\"\"\n    if n < 2:\n        return False\n    for i in range(2, n):\n        if n % i == 0:\n            return False\n    return True\n\n# 编写测试\n# 你的代码\n\ndef test_one_is_not_prime():\n    assert not is_prime(1)\n\ndef test_two_is_prime():\n    assert is_prime(2)\n\ndef test_even_numbers_not_prime():\n    for n in [4, 6, 8, 10]:\n        assert not is_prime(n)\n\n# 运行: pytest test_file.py -v",
    "solution": "# pytest 测试示例\n\ndef is_prime(n):\n    \"\"\"判断是否为质数\"\"\"\n    if n < 2:\n        return False\n    for i in range(2, int(n ** 0.5) + 1):\n        if n % i == 0:\n            return False\n    return True\n\ndef test_one_is_not_prime():\n    assert not is_prime(1)\n\ndef test_two_is_prime():\n    assert is_prime(2)\n\ndef test_even_numbers_not_prime():\n    for n in [4, 6, 8, 10]:\n        assert not is_prime(n)\n\ndef test_known_primes():\n    primes = [2, 3, 5, 7, 11, 13, 17, 19, 23]\n    for p in primes:\n        assert is_prime(p)\n\ndef test_negative_numbers():\n    assert not is_prime(-1)\n    assert not is_prime(-5)\n\n# pytest 自动发现并运行所有 test_ 开头的函数",
    "tags": [
      "pytest",
      "测试"
    ]
  },
  {
    "id": "ex_unit_003",
    "module": "unit_testing",
    "title": "测试夹具 (Fixtures)",
    "difficulty": "medium",
    "points": 15,
    "description": "使用 pytest fixtures",
    "starter_code": "import pytest\n\nclass Calculator:\n    def __init__(self):\n        self.result = 0\n    \n    def add(self, n):\n        self.result += n\n        return self\n    \n    def subtract(self, n):\n        self.result -= n\n        return self\n    \n    def get_result(self):\n        return self.result\n\n# 创建 fixture\n@pytest.fixture\ndef calculator():\n    return Calculator()\n\n# 使用 fixture\ndef test_calculator_add(calculator):\n    # 你的代码\n    pass\n\ndef test_calculator_chain(calculator):\n    # 测试链式调用\n    # 你的代码\n    pass",
    "solution": "import pytest\n\nclass Calculator:\n    def __init__(self):\n        self.result = 0\n    \n    def add(self, n):\n        self.result += n\n        return self\n    \n    def subtract(self, n):\n        self.result -= n\n        return self\n    \n    def multiply(self, n):\n        self.result *= n\n        return self\n    \n    def get_result(self):\n        return self.result\n    \n    def reset(self):\n        self.result = 0\n        return self\n\n# 创建 fixture\n@pytest.fixture\ndef calculator():\n    return Calculator()\n\n# 使用 fixture\ndef test_calculator_add(calculator):\n    calculator.add(5)\n    assert calculator.get_result() == 5\n\ndef test_calculator_subtract(calculator):\n    calculator.add(10)\n    calculator.subtract(3)\n    assert calculator.get_result() == 7\n\ndef test_calculator_chain(calculator):\n    result = calculator.add(10).subtract(5).multiply(2).get_result()\n    assert result == 10\n\ndef test_calculator_reset(calculator):\n    calculator.add(100)\n    calculator.reset()\n    assert calculator.get_result() == 0",
    "tags": [
      "fixture",
      "pytest"
    ]
  },
  {
    "id": "ex_unit_004",
    "module": "unit_testing",
    "title": "Mock 对象",
    "difficulty": "medium",
    "points": 15,
    "description": "使用 unittest.mock",
    "starter_code": "from unittest.mock import Mock, patch\n\ndef get_user_from_api(user_id):\n    import requests\n    response = requests.get(f'https://api.example.com/users/{user_id}')\n    return response.json()\n\n# 测试不依赖真实 API\ndef test_get_user():\n    # 使用 patch 模拟 requests.get\n    # 你的代码\n    \n    # 验证\n    user = get_user_from_api(123)\n    assert user['name'] == 'Alice'\n\ndef test_api_not_found():\n    # 测试 API 返回 404 的情况\n    pass",
    "solution": "from unittest.mock import Mock, patch\n\ndef get_user_from_api(user_id):\n    import requests\n    response = requests.get(f'https://api.example.com/users/{user_id}')\n    if response.status_code == 200:\n        return response.json()\n    return None\n\n# 测试不依赖真实 API\ndef test_get_user():\n    mock_response = Mock()\n    mock_response.status_code = 200\n    mock_response.json.return_value = {'id': 123, 'name': 'Alice'}\n    \n    with patch('requests.get', return_value=mock_response):\n        user = get_user_from_api(123)\n        assert user['name'] == 'Alice'\n\ndef test_api_not_found():\n    mock_response = Mock()\n    mock_response.status_code = 404\n    \n    with patch('requests.get', return_value=mock_response):\n        user = get_user_from_api(999)\n        assert user is None\n\ndef test_api_error():\n    mock_response = Mock()\n    mock_response.status_code = 500\n    \n    with patch('requests.get', return_value=mock_response):\n        user = get_user_from_api(1)\n        assert user is None",
    "tags": [
      "Mock",
      "unittest"
    ]
  },
  {
    "id": "ex_unit_005",
    "module": "unit_testing",
    "title": "测试覆盖率",
    "difficulty": "hard",
    "points": 20,
    "description": "使用 pytest-cov 计算覆盖率",
    "starter_code": "def calculate_grade(score):\n    \"\"\"根据分数计算等级\"\"\"\n    if score >= 90:\n        return 'A'\n    elif score >= 80:\n        return 'B'\n    elif score >= 70:\n        return 'C'\n    elif score >= 60:\n        return 'D'\n    else:\n        return 'F'\n\ndef get_pass_status(score):\n    \"\"\"判断是否及格\"\"\"\n    return score >= 60\n\n# 编写完整测试\ndef test_grade_a():\n    assert calculate_grade(95) == 'A'\n\ndef test_grade_b():\n    assert calculate_grade(85) == 'B'\n\n# 添加更多测试覆盖所有分支\n\n# 运行: pytest test_file.py --cov=. --cov-report=term-missing",
    "solution": "def calculate_grade(score):\n    \"\"\"根据分数计算等级\"\"\"\n    if score >= 90:\n        return 'A'\n    elif score >= 80:\n        return 'B'\n    elif score >= 70:\n        return 'C'\n    elif score >= 60:\n        return 'D'\n    else:\n        return 'F'\n\ndef get_pass_status(score):\n    \"\"\"判断是否及格\"\"\"\n    return score >= 60\n\n# 完整测试覆盖所有分支\ndef test_grade_a():\n    assert calculate_grade(95) == 'A'\n    assert calculate_grade(100) == 'A'\n\ndef test_grade_b():\n    assert calculate_grade(85) == 'B'\n    assert calculate_grade(80) == 'B'\n\ndef test_grade_c():\n    assert calculate_grade(75) == 'C'\n    assert calculate_grade(70) == 'C'\n\ndef test_grade_d():\n    assert calculate_grade(65) == 'D'\n    assert calculate_grade(60) == 'D'\n\ndef test_grade_f():\n    assert calculate_grade(59) == 'F'\n    assert calculate_grade(0) == 'F'\n    assert calculate_grade(-10) == 'F'\n\ndef test_pass():\n    assert get_pass_status(60) == True\n    assert get_pass_status(100) == True\n\ndef test_fail():\n    assert get_pass_status(59) == False\n    assert get_pass_status(0) == False\n\n# 运行: pytest test_file.py --cov=. --cov-report=term-missing",
    "tags": [
      "覆盖率",
      "测试"
    ]
  },
  {
    "id": "ex_debug_001",
    "module": "debugging",
    "title": "pdb 调试基础",
    "difficulty": "easy",
    "points": 10,
    "description": "使用 pdb 进行调试",
    "starter_code": "# pdb 调试示例\n\ndef buggy_function(numbers):\n    result = 0\n    for i, num in enumerate(numbers):\n        result = result + num\n        if i == 2:\n            break  # 这里有 bug\n    return result\n\n# 使用 pdb.set_trace() 调试\n# 你的代码\n\ndata = [1, 2, 3, 4, 5]\nprint(f'求和结果: {buggy_function(data)}')",
    "solution": "# pdb 调试示例\n\ndef buggy_function(numbers):\n    result = 0\n    for i, num in enumerate(numbers):\n        result = result + num\n        if i == 2:\n            break  # 这里有 bug: 提前退出循环\n    return result\n\ndef correct_function(numbers):\n    result = 0\n    for num in numbers:\n        result = result + num\n    return result\n\n# 不使用 pdb，直接演示\ndata = [1, 2, 3, 4, 5]\nprint(f'原函数结果: {buggy_function(data)}')  # 只求和前3个\nprint(f'正确结果: {correct_function(data)}')\n\n# pdb 常用命令:\n# n (next) - 执行下一行\n# s (step) - 进入函数\n# p variable - 打印变量\n# c (continue) - 继续执行\n# q (quit) - 退出\n\nprint('\\npdb 调试方法:')\nprint('import pdb; pdb.set_trace()')",
    "tags": [
      "pdb",
      "调试"
    ]
  },
  {
    "id": "ex_debug_002",
    "module": "debugging",
    "title": "日志记录",
    "difficulty": "easy",
    "points": 10,
    "description": "使用 logging 模块",
    "starter_code": "import logging\n\n# 配置日志\nlogging.basicConfig(level=logging.DEBUG)\nlogger = logging.getLogger(__name__)\n\ndef divide(a, b):\n    logger.debug(f'开始计算: {a} / {b}')\n    if b == 0:\n        logger.error('除数不能为零!')\n        return None\n    result = a / b\n    logger.info(f'计算结果: {result}')\n    return result\n\n# 测试\nprint(divide(10, 2))\nprint(divide(10, 0))",
    "solution": "import logging\n\n# 配置日志\nlogging.basicConfig(\n    level=logging.DEBUG,\n    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n)\nlogger = logging.getLogger(__name__)\n\ndef divide(a, b):\n    logger.debug(f'开始计算: {a} / {b}')\n    if b == 0:\n        logger.error('除数不能为零!')\n        return None\n    result = a / b\n    logger.info(f'计算结果: {result}')\n    return result\n\ndef process_data(data):\n    logger.info(f'处理数据: {data}')\n    try:\n        result = sum(data)\n        logger.info(f'求和结果: {result}')\n        return result\n    except Exception as e:\n        logger.error(f'处理失败: {e}')\n        return None\n\n# 测试\nprint('除法测试:')\nprint(divide(10, 2))\nprint(divide(10, 0))\n\nprint('\\n数据处理测试:')\nprint(process_data([1, 2, 3, 4, 5]))\nprint(process_data([]))",
    "tags": [
      "logging",
      "日志"
    ]
  },
  {
    "id": "ex_debug_003",
    "module": "debugging",
    "title": "断言与异常",
    "difficulty": "medium",
    "points": 15,
    "description": "使用断言和异常处理调试",
    "starter_code": "def calculate_average(numbers):\n    \"\"\"计算平均值\"\"\"\n    assert len(numbers) > 0, '列表不能为空'\n    \n    total = sum(numbers)\n    count = len(numbers)\n    \n    return total / count\n\ndef find_element(data, target):\n    \"\"\"在列表中查找元素\"\"\"\n    for i, item in enumerate(data):\n        if item == target:\n            return i\n    return -1\n\n# 测试断言\nprint(calculate_average([1, 2, 3, 4, 5]))\nprint(calculate_average([]))  # 会触发 AssertionError",
    "solution": "def calculate_average(numbers):\n    \"\"\"计算平均值\"\"\"\n    assert len(numbers) > 0, '列表不能为空'\n    \n    total = sum(numbers)\n    count = len(numbers)\n    \n    return total / count\n\ndef find_element(data, target):\n    \"\"\"在列表中查找元素\"\"\"\n    for i, item in enumerate(data):\n        if item == target:\n            return i\n    raise ValueError(f'元素 {target} 不在列表中')\n\n# 测试断言\nprint('平均值测试:')\nprint(calculate_average([1, 2, 3, 4, 5]))\n\n# 测试异常处理\nprint('\\n查找测试:')\ndata = ['apple', 'banana', 'orange']\ntry:\n    idx = find_element(data, 'banana')\n    print(f'banana 在索引 {idx}')\n    \n    idx = find_element(data, 'grape')\n    print(f'grape 在索引 {idx}')\nexcept ValueError as e:\n    print(f'异常: {e}')\n\n# 演示 try-except-finally\nprint('\\nfinally 用法:')\ntry:\n    result = 10 / 2\nexcept ZeroDivisionError:\n    print('除数不能为零')\nfinally:\n    print('清理资源...')",
    "tags": [
      "断言",
      "异常"
    ]
  },
  {
    "id": "ex_debug_004",
    "module": "debugging",
    "title": "性能分析",
    "difficulty": "medium",
    "points": 15,
    "description": "使用 timeit 测量性能",
    "starter_code": "import timeit\n\n# 方法1: 使用 timeit\ndef slow_function():\n    total = 0\n    for i in range(1000):\n        total += i\n    return total\n\ndef fast_function():\n    return sum(range(1000))\n\n# 测量执行时间\n# 你的代码\n\nprint(f'slow_function: {slow_time:.6f} 秒')\nprint(f'fast_function: {fast_time:.6f} 秒')",
    "solution": "import timeit\n\n# 方法1: 使用 timeit\ndef slow_function():\n    total = 0\n    for i in range(1000):\n        total += i\n    return total\n\ndef fast_function():\n    return sum(range(1000))\n\ndef faster_function():\n    return sum(range(0, 1000, 1))\n\n# 测量执行时间\nslow_time = timeit.timeit(slow_function, number=10000)\nfast_time = timeit.timeit(fast_function, number=10000)\nfaster_time = timeit.timeit(faster_function, number=10000)\n\nprint('性能对比 (10000次):')\nprint(f'慢方法 (for循环): {slow_time:.6f} 秒')\nprint(f'快方法 (sum+range): {fast_time:.6f} 秒')\nprint(f'最快 (直接range): {faster_time:.6f} 秒')\nprint(f'\\n快速方法比慢方法快 {(slow_time/fast_time):.1f}x')",
    "tags": [
      "timeit",
      "性能"
    ]
  },
  {
    "id": "ex_debug_005",
    "module": "debugging",
    "title": "内存分析",
    "difficulty": "hard",
    "points": 20,
    "description": "使用 memory_profiler 分析内存",
    "starter_code": "# memory_profiler 示例\n# pip install memory_profiler\n\n@profile\ndef memory_intensive_function():\n    \"\"\"模拟内存密集操作\"\"\"\n    data = []\n    for i in range(100000):\n        data.append(i * 2)\n    \n    result = sum(data)\n    return result\n\n# 简化演示\ndef demo_memory_usage():\n    import sys\n    \n    # 创建不同大小的对象\n    small_list = list(range(100))\n    large_list = list(range(100000))\n    \n    print(f'小列表大小: {sys.getsizeof(small_list)} bytes')\n    print(f'大列表大小: {sys.getsizeof(large_list)} bytes')\n    \n    return small_list, large_list\n\nsmall, large = demo_memory_usage()\nprint(f'返回后大列表仍然存在: {len(large)} 元素')",
    "solution": "# memory_profiler 示例\n# 运行: python -m memory_profiler demo.py\n\ndef demo_memory_usage():\n    import sys\n    \n    # 创建不同大小的对象\n    small_list = list(range(100))\n    large_list = list(range(100000))\n    large_list_copy = large_list.copy()\n    \n    # 计算预估内存\n    small_size = sys.getsizeof(small_list) + sum(sys.getsizeof(x) for x in small_list)\n    large_size = sys.getsizeof(large_list) + sum(sys.getsizeof(x) for x in large_list)\n    \n    print(f'小列表 (100元素) 估计内存: ~{small_size/1024:.2f} KB')\n    print(f'大列表 (100000元素) 估计内存: ~{large_size/1024/1024:.2f} MB')\n    \n    # 使用生成器节省内存\n    def gen_range(n):\n        for i in range(n):\n            yield i\n    \n    gen = gen_range(100000)\n    gen_size = sys.getsizeof(gen)\n    print(f'\\n生成器对象大小: {gen_size} bytes')\n    print('生成器是惰性计算，不占用大量内存')\n    \n    return small_list, large_list\n\nsmall, large = demo_memory_usage()\nprint(f'\\n返回后大列表元素数: {len(large):,}')",
    "tags": [
      "内存",
      "profiler"
    ]
  }
]