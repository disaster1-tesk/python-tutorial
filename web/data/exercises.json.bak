    "id": "ex_dl_001",
    "module": "deep_learning",
    "title": "神经网络基础",
    "difficulty": "medium",
    "points": 15,
    "description": "使用 PyTorch 构建简单神经网络",
    "starter_code": "import torch\nimport torch.nn as nn\n\n# 定义神经网络\nclass SimpleNN(nn.Module):\n    def __init__(self, input_size, hidden_size, num_classes):\n        super(SimpleNN, self).__init__()\n        # 定义层\n        # 你的代码\n        \n    def forward(self, x):\n        # 前向传播\n        # 你的代码\n        return x\n\n# 测试\nmodel = SimpleNN(784, 128, 10)\nprint(model)\n\n# 测试输入\nx = torch.randn(1, 784)\noutput = model(x)\nprint(f'输出形状: {output.shape}')",
    "solution": "import torch\nimport torch.nn as nn\n\n# 定义神经网络\nclass SimpleNN(nn.Module):\n    def __init__(self, input_size, hidden_size, num_classes):\n        super(SimpleNN, self).__init__()\n        self.layer1 = nn.Linear(input_size, hidden_size)\n        self.relu = nn.ReLU()\n        self.layer2 = nn.Linear(hidden_size, num_classes)\n        \n    def forward(self, x):\n        x = self.layer1(x)\n        x = self.relu(x)\n        x = self.layer2(x)\n        return x\n\n# 测试\nmodel = SimpleNN(784, 128, 10)\nprint('模型结构:')\nprint(model)\n\n# 统计参数\ntotal_params = sum(p.numel() for p in model.parameters())\nprint(f'\\n总参数量: {total_params:,}')\n\n# 测试输入\nx = torch.randn(1, 784)\noutput = model(x)\nprint(f'输入形状: {x.shape}')\nprint(f'输出形状: {output.shape}')",
    "tags": [
      "神经网络",
      "PyTorch"
    ]
  },
  {
    "id": "ex_dl_002",
    "module": "deep_learning",
    "title": "卷积神经网络",
    "difficulty": "medium",
    "points": 15,
    "description": "构建 CNN 进行图像分类",
    "starter_code": "import torch\nimport torch.nn as nn\n\nclass CNN(nn.Module):\n    def __init__(self):\n        super(CNN, self).__init__()\n        # 卷积层\n        self.conv1 = nn.Conv2d(3, 32, kernel_size=3, padding=1)\n        self.conv2 = nn.Conv2d(32, 64, kernel_size=3, padding=1)\n        # 池化层\n        self.pool = nn.MaxPool2d(2, 2)\n        # 全连接层\n        self.fc1 = nn.Linear(64 * 8 * 8, 128)\n        self.fc2 = nn.Linear(128, 10)\n        \n    def forward(self, x):\n        # 实现前向传播\n        # 你的代码\n        return x\n\nmodel = CNN()\nprint(model)\n\n# 测试\nx = torch.randn(1, 3, 32, 32)\noutput = model(x)\nprint(f'输出形状: {output.shape}')",
    "solution": "import torch\nimport torch.nn as nn\n\nclass CNN(nn.Module):\n    def __init__(self):\n        super(CNN, self).__init__()\n        # 卷积层\n        self.conv1 = nn.Conv2d(3, 32, kernel_size=3, padding=1)\n        self.conv2 = nn.Conv2d(32, 64, kernel_size=3, padding=1)\n        # 池化层\n        self.pool = nn.MaxPool2d(2, 2)\n        self.relu = nn.ReLU()\n        # 全连接层\n        self.fc1 = nn.Linear(64 * 8 * 8, 128)\n        self.fc2 = nn.Linear(128, 10)\n        \n    def forward(self, x):\n        x = self.pool(self.relu(self.conv1(x)))  # 32->16\n        x = self.pool(self.relu(self.conv2(x)))  # 64->8\n        x = x.view(-1, 64 * 8 * 8)\n        x = self.relu(self.fc1(x))\n        x = self.fc2(x)\n        return x\n\nmodel = CNN()\nprint('CNN 模型结构:')\nprint(model)\n\n# 测试\nx = torch.randn(1, 3, 32, 32)\noutput = model(x)\nprint(f'\\n输入形状: {x.shape}')\nprint(f'输出形状: {output.shape}')",
    "tags": [
      "CNN",
      "图像"
    ]
  },
  {
    "id": "ex_dl_003",
    "module": "deep_learning",
    "title": "训练循环",
    "difficulty": "medium",
    "points": 15,
    "description": "实现完整的训练循环",
    "starter_code": "import torch\nimport torch.nn as nn\nimport torch.optim as optim\n\n# 简单模型和数据\nmodel = nn.Linear(10, 2)\ncriterion = nn.CrossEntropyLoss()\noptimizer = optim.SGD(model.parameters(), lr=0.01)\n\n# 模拟数据\nX = torch.randn(100, 10)\ny = torch.randint(0, 2, (100,))\n\n# 训练循环\nfor epoch in range(5):\n    # 前向传播\n    # 你的代码\n    \n    # 反向传播\n    # 你的代码\n    \n    # 更新参数\n    # 你的代码\n    \n    print(f'Epoch {epoch+1}, Loss: {loss.item():.4f}')",
    "solution": "import torch\nimport torch.nn as nn\nimport torch.optim as optim\n\n# 简单模型和数据\nmodel = nn.Linear(10, 2)\ncriterion = nn.CrossEntropyLoss()\noptimizer = optim.SGD(model.parameters(), lr=0.01)\n\n# 模拟数据\nX = torch.randn(100, 10)\ny = torch.randint(0, 2, (100,))\n\n# 训练循环\nfor epoch in range(5):\n    # 前向传播\n    outputs = model(X)\n    loss = criterion(outputs, y)\n    \n    # 反向传播\n    optimizer.zero_grad()\n    loss.backward()\n    \n    # 更新参数\n    optimizer.step()\n    \n    print(f'Epoch {epoch+1}, Loss: {loss.item():.4f}')\n\nprint('\\n训练完成!')",
    "tags": [
      "训练",
      "优化"
    ]
  },
  {
    "id": "ex_dl_004",
    "module": "deep_learning",
    "title": "Dropout 和正则化",
    "difficulty": "hard",
    "points": 20,
    "description": "使用 Dropout 防止过拟合",
    "starter_code": "import torch\nimport torch.nn as nn\n\nclass DropoutNet(nn.Module):\n    def __init__(self, input_size, hidden_size, num_classes, dropout_rate=0.5):\n        super(DropoutNet, self).__init__()\n        self.fc1 = nn.Linear(input_size, hidden_size)\n        self.relu = nn.ReLU()\n        # 添加 Dropout\n        # 你的代码\n        self.fc2 = nn.Linear(hidden_size, hidden_size)\n        self.fc3 = nn.Linear(hidden_size, num_classes)\n        \n    def forward(self, x):\n        x = self.relu(self.fc1(x))\n        x = self.dropout(x)  # 训练时丢弃\n        x = self.relu(self.fc2(x))\n        x = self.dropout(x)\n        x = self.fc3(x)\n        return x\n\nmodel = DropoutNet(784, 256, 10)\nprint(model)\n\n# 测试训练和评估模式\nmodel.train()  # 训练模式\nmodel.eval()   # 评估模式",
    "solution": "import torch\nimport torch.nn as nn\n\nclass DropoutNet(nn.Module):\n    def __init__(self, input_size, hidden_size, num_classes, dropout_rate=0.5):\n        super(DropoutNet, self).__init__()\n        self.fc1 = nn.Linear(input_size, hidden_size)\n        self.relu = nn.ReLU()\n        self.dropout = nn.Dropout(p=dropout_rate)\n        self.fc2 = nn.Linear(hidden_size, hidden_size)\n        self.fc3 = nn.Linear(hidden_size, num_classes)\n        \n    def forward(self, x):\n        x = self.relu(self.fc1(x))\n        x = self.dropout(x)\n        x = self.relu(self.fc2(x))\n        x = self.dropout(x)\n        x = self.fc3(x)\n        return x\n\nmodel = DropoutNet(784, 256, 10)\nprint('Dropout 网络:')\nprint(model)\n\n# 测试训练和评估模式\nmodel.train()\nprint('\\n训练模式: dropout 生效')\nmodel.eval()\nprint('评估模式: dropout 禁用')",
    "tags": [
      "Dropout",
      "正则化"
    ]
  },
  {
    "id": "ex_dl_005",
    "module": "deep_learning",
    "title": "迁移学习",
    "difficulty": "hard",
    "points": 20,
    "description": "使用预训练模型",
    "starter_code": "import torchvision.models as models\n\n# 加载预训练 ResNet\nmodel = models.resnet18(pretrained=True)\n\n# 查看模型结构\nprint(model)\n\n# 冻结部分参数\nfor param in model.parameters():\n    param.requires_grad = False\n\n# 替换最后的全连接层\n# 你的代码\n\nprint('\\n修改后的分类层:')\nprint(model.fc)",
    "solution": "import torchvision.models as models\nimport torch.nn as nn\n\n# 加载预训练 ResNet\nmodel = models.resnet18(weights='IMAGENET1K_V1')\n\n# 查看模型结构\nprint('原始 ResNet18 最后层:')\nprint(model.fc)\n\n# 冻结部分参数\nfor param in model.parameters():\n    param.requires_grad = False\n\n# 替换最后的全连接层 (512 -> 10 类)\nnum_features = model.fc.in_features\nmodel.fc = nn.Linear(num_features, 10)\n\nprint('\\n修改后的分类层:')\nprint(model.fc)\n\n# 只有新层需要训练\ntrainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\nprint(f'\\n可训练参数量: {trainable_params:,}')",
    "tags": [
      "迁移学习",
      "ResNet"
    ]
  },
  {
    "id": "ex_nlp_001",
    "module": "nlp_and_llm",
    "title": "文本分词",
    "difficulty": "easy",
    "points": 10,
    "description": "使用分词器处理文本",
    "starter_code": "# 使用 transformers 进行分词\nfrom transformers import AutoTokenizer\n\n# 加载分词器\ntokenizer = AutoTokenizer.from_pretrained('bert-base-chinese')\n\ntext = \"今天天气真好，我们去公园玩吧！\"\n\n# 分词\n# 你的代码\n\nprint(f'原始文本: {text}')\nprint(f'分词结果: {tokens}')\nprint(f'词数: {len(tokens)}')",
    "solution": "# 使用 transformers 进行分词\nfrom transformers import AutoTokenizer\n\n# 加载分词器\ntry:\n    tokenizer = AutoTokenizer.from_pretrained('bert-base-chinese')\n    \n    text = \"今天天气真好，我们去公园玩吧！\"\n    \n    # 分词\n    tokens = tokenizer.tokenize(text)\n    \n    print(f'原始文本: {text}')\n    print(f'分词结果: {tokens}')\n    print(f'词数: {len(tokens)}')\n    \nexcept Exception as e:\n    print('使用模拟分词器演示:')\n    text = \"今天天气真好，我们去公园玩吧！\"\n    # 简单按字符分词\n    tokens = list(text.replace('！', '').replace('，', '').replace(' ', ''))\n    print(f'原始文本: {text}')\n    print(f'分词结果: {tokens}')\n    print(f'词数: {len(tokens)}')",
