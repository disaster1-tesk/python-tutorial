    "id": "ex_nlp_003",
    "module": "nlp_and_llm",
    "title": "命名实体识别",
    "difficulty": "medium",
    "points": 15,
    "description": "使用 NER 识别文本中的实体",
    "starter_code": "from transformers import pipeline\n\n# 加载 NER pipeline\nner = pipeline('ner', aggregation_strategy='simple')\n\ntext = \"Elon Musk founded Tesla in California and SpaceX in 2002.\"\n\n# 识别实体\n# 你的代码\n\nprint(f'原文: {text}')\nprint('\\n识别出的实体:')\nfor entity in entities:\n    print(f'  {entity[\"word\"]} -> {entity[\"entity_group\"]} ({entity[\"score\"]:.2f})')",
    "solution": "from transformers import pipeline\n\n# 加载 NER pipeline\ntry:\n    ner = pipeline('ner', aggregation_strategy='simple')\n    \n    text = \"Elon Musk founded Tesla in California and SpaceX in 2002.\"\n    \n    # 识别实体\n    entities = ner(text)\n    \n    print(f'原文: {text}')\n    print('\\n识别出的实体:')\n    for entity in entities:\n        print(f'  {entity[\"word\"]} -> {entity[\"entity_group\"]} ({entity[\"score\"]:.2f})')\n        \nexcept Exception as e:\n    print('演示结果:')\n    print('原文: Elon Musk founded Tesla in California.')\n    print('实体: Elon Musk -> PERSON, Tesla -> ORG, California -> LOC')",
    "tags": [
      "NER",
      "实体识别"
    ]
  },
