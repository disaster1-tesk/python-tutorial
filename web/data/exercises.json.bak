  {
    "id": "ex_custom_skill_002",
    "module": "custom_skill",
    "title": "Skill 工具开发",
    "difficulty": "medium",
    "points": 15,
    "description": "在 Skill 中实现可调用的工具函数",
    "starter_code": "# Skill 工具函数\ndef process_data(data, mode='default'):\n    '''处理数据的工具函数'''\n    # 实现\n    pass\n\ndef transform_format(data, target='json'):\n    '''格式转换工具'''\n    # 实现\n    pass",
    "solution": "import json\n\ndef process_data(data, mode='default'):\n    '''\n    数据处理工具\n    \n    参数:\n        data: 输入数据\n        mode: 处理模式 (default/advanced)\n    \n    返回:\n        处理后的数据\n    '''\n    if mode == 'default':\n        return f'默认处理: {data}'\n    elif mode == 'advanced':\n        return f'高级处理: {data.upper()} * 2'\n    return data\n\ndef transform_format(data, target='json'):\n    '''\n    格式转换工具\n    \n    参数:\n        data: 输入数据\n        target: 目标格式 (json/csv/text)\n    '''\n    if target == 'json':\n        return json.dumps(data, ensure_ascii=False)\n    elif target == 'csv':\n        if isinstance(data, list):\n            return ','.join(str(v) for v in data)\n        return str(data)\n    return str(data)\n\n# 测试\nprint(process_data('hello', 'default'))\nprint(process_data('hello', 'advanced'))\nprint()\nprint(transform_format({'name': 'test'}, 'json'))\nprint(transform_format([1, 2, 3], 'csv'))",
    "tags": [
      "Skill",
      "工具"
    ]
  },
  {
    "id": "ex_multi_agent_001",
    "module": "multi_agent",
    "title": "基础 Agent 实现",
    "difficulty": "medium",
    "points": 15,
    "description": "创建一个能收发消息的基础 Agent",
    "starter_code": "class BaseAgent:\n    def __init__(self, agent_id, name):\n        self.agent_id = agent_id\n        self.name = name\n        self.inbox = []\n        self.outbox = []\n    \n    def receive(self, message):\n        # 接收消息\n        pass\n    \n    def send(self, receiver, message):\n        # 发送消息\n        pass\n    \n    def process(self):\n        # 处理消息\n        pass",
    "solution": "class BaseAgent:\n    \"\"\"基础 Agent\"\"\"\n    def __init__(self, agent_id, name):\n        self.agent_id = agent_id\n        self.name = name\n        self.inbox = []\n        self.outbox = []\n    \n    def receive(self, message):\n        self.inbox.append(message)\n        print(f'📥 {self.name} 收到消息: {message.get(\"type\")}')\n    \n    def send(self, receiver, message):\n        message['from'] = self.agent_id\n        message['to'] = receiver.agent_id\n        self.outbox.append(message)\n        print(f'📤 {self.name} 发送消息给 {receiver.name}')\n    \n    def process(self):\n        while self.inbox:\n            message = self.inbox.pop(0)\n            print(f'🔄 {self.name} 处理: {message}')\n            # 简单处理：返回确认\n            self.outbox.append({\n                'type': 'response',\n                'content': f'已处理: {message.get(\"content\")}'\n            })\n\n# 测试\nalice = BaseAgent('agent1', 'Alice')\nbob = BaseAgent('agent2', 'Bob')\n\n# 发送消息\nalice.send(bob, {'type': 'greeting', 'content': '你好！'})\n\n# Bob 处理消息\nbob.process()\n\nprint(f'Alice 收件箱: {len(alice.inbox)}')\nprint(f'Bob 收件箱: {len(bob.inbox)}')\nprint(f'Alice 发件箱: {len(alice.outbox)}')\nprint(f'Bob 发件箱: {len(bob.outbox)}')",
    "tags": [
      "Agent",
      "通信"
    ]
  },
  {
    "id": "ex_multi_agent_002",
    "module": "multi_agent",
    "title": "任务分配器",
    "difficulty": "medium",
    "points": 15,
    "description": "实现智能任务分配系统",
    "starter_code": "class TaskScheduler:\n    def __init__(self):\n        self.agents = {}\n        self.tasks = []\n    \n    def add_agent(self, agent_id, capabilities):\n        # 添加 Agent\n        pass\n    \n    def add_task(self, task):\n        # 添加任务\n        pass\n    \n    def schedule(self):\n        # 分配任务\n        pass",
    "solution": "class TaskScheduler:\n    \"\"\"任务调度器\"\"\"\n    def __init__(self):\n        self.agents = {}\n        self.tasks = []\n    \n    def add_agent(self, agent_id, capabilities, load=0):\n        self.agents[agent_id] = {\n            'capabilities': capabilities,\n            'load': load\n        }\n        print(f'✓ Agent {agent_id}: {capabilities}')\n    \n    def add_task(self, task_name, required_skill, priority=1):\n        self.tasks.append({\n            'name': task_name,\n            'skill': required_skill,\n            'priority': priority\n        })\n        print(f'+ 任务: {task_name} (需要: {required_skill})')\n    \n    def schedule(self):\n        assignments = []\n        for task in self.tasks:\n            best_agent = None\n            best_score = -1\n            \n            for agent_id, agent in self.agents.items():\n                if task['skill'] in agent['capabilities']:\n                    score = 100 - agent['load']  # 负载越低分数越高\n                    if score > best_score:\n                        best_score = score\n                        best_agent = agent_id\n            \n            if best_agent:\n                assignments.append((best_agent, task))\n                self.agents[best_agent]['load'] += 1\n                print(f'✓ 任务 \"{task[\"name\"]}\" -> {best_agent}')\n            else:\n                print(f'✗ 任务 \"{task[\"name\"]}\" 无可用 Agent')\n        \n        return assignments\n\n# 测试\nscheduler = TaskScheduler()\n\n# 添加 Agent\nscheduler.add_agent('Agent1', ['python', 'data'])\nscheduler.add_agent('Agent2', ['web', 'api'])\nscheduler.add_agent('Agent3', ['python', 'ml'])\n\nprint()\n# 添加任务\nscheduler.add_task('数据分析', 'python')\nscheduler.add_task('Web 开发', 'web')\nscheduler.add_task('机器学习', 'python')\nscheduler.add_task('API 开发', 'api')\n\nprint()\n# 调度\nscheduler.schedule()",
    "tags": [
      "Agent",
      "任务分配"
    ]
  },
  {
    "id": "ex_multi_agent_003",
    "module": "multi_agent",
    "title": "多 Agent 协作工作流",
    "difficulty": "hard",
    "points": 20,
    "description": "实现多 Agent 协同完成复杂任务",
    "starter_code": "class Workflow:\n    def __init__(self):\n        self.steps = []\n    \n    def add_step(self, agent_role, action):\n        # 添加步骤\n        pass\n    \n    def execute(self, initial_data):\n        # 执行工作流\n        pass",
    "solution": "class MultiAgentWorkflow:\n    \"\"\"多 Agent 协作工作流\"\"\"\n    def __init__(self, name):\n        self.name = name\n        self.steps = []\n    \n    def add_step(self, agent_role, action):\n        self.steps.append({\n            'role': agent_role,\n            'action': action\n        })\n    \n    def execute(self, context):\n        print(f'🚀 开始执行工作流: {self.name}')\n        print(f'初始数据: {context}')\n        print()\n        \n        results = []\n        current_data = context.copy()\n        \n        for i, step in enumerate(self.steps, 1):\n            print(f'步骤 {i}: {step[\"role\"]} 执行 {step[\"action\"]}')\n            \n            # 模拟执行\n            if step['role'] == 'researcher':\n                result = f'研究发现: {current_data.get(\"topic\", \"N/A\")} 相关资料'\n            elif step['role'] == 'coder':\n                result = f'代码实现: 完成 {current_data.get(\"topic\", \"N/A\")} 功能'\n            elif step['role'] == 'tester':\n                result = '测试通过: 所有用例通过'\n            elif step['role'] == 'writer':\n                result = '文档完成: 完整使用文档'\n            else:\n                result = '未知角色'\n            \n            print(f'  结果: {result}')\n            print()\n            results.append(result)\n            current_data[f'step_{i}'] = result\n        \n        print(f'✅ 工作流完成! 共 {len(results)} 个步骤')\n        return current_data\n\n# 创建工作流\nworkflow = MultiAgentWorkflow('新功能开发')\nworkflow.add_step('researcher', '调研 AI 技术')\nworkflow.add_step('coder', '实现核心功能')\nworkflow.add_step('tester', '测试功能')\nworkflow.add_step('writer', '编写文档')\n\n# 执行\nresult = workflow.execute({'topic': '用户认证'})\nprint(f'最终数据: {result}')",
    "tags": [
      "Agent",
      "工作流"
    ]
  },
