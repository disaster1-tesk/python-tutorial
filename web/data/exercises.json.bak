    "id": "ex_web_002",
    "module": "web_development",
    "title": "Flask 模板",
    "difficulty": "easy",
    "points": 10,
    "description": "使用 Jinja2 模板",
    "starter_code": "from flask import Flask, render_template_string\n\napp = Flask(__name__)\n\n# 内联模板\nhtml = '''\n<!DOCTYPE html>\n<html>\n<head><title>用户列表</title></head>\n<body>\n    <h1>用户列表</h1>\n    <ul>\n    {% for user in users %}\n        <li>{{ user.name }} - {{ user.email }}</li>\n    {% endfor %}\n    </ul>\n</body>\n</html>\n'''\n\nusers = [\n    {'name': 'Alice', 'email': 'alice@example.com'},\n    {'name': 'Bob', 'email': 'bob@example.com'},\n]\n\n@app.route('/')\ndef index():\n    return render_template_string(html, users=users)\n\nif __name__ == '__main__':\n    app.run(debug=True)",
    "solution": "from flask import Flask, render_template_string\n\napp = Flask(__name__)\n\n# 内联模板\nhtml = '''\n<!DOCTYPE html>\n<html>\n<head><title>用户列表</title></head>\n<body>\n    <h1>用户列表</h1>\n    <ul>\n    {% for user in users %}\n        <li>{{ user.name }} - {{ user.email }}</li>\n    {% endfor %}\n    </ul>\n    <p>共 {{ users|length }} 位用户</p>\n</body>\n</html>\n'''\n\nusers = [\n    {'name': 'Alice', 'email': 'alice@example.com'},\n    {'name': 'Bob', 'email': 'bob@example.com'},\n]\n\n@app.route('/')\ndef index():\n    return render_template_string(html, users=users)\n\nif __name__ == '__main__':\n    app.run(debug=True)",
    "tags": [
      "Jinja2",
      "模板"
    ]
  },
  {
    "id": "ex_web_003",
    "module": "web_development",
    "title": "REST API",
    "difficulty": "medium",
    "points": 15,
    "description": "创建 RESTful API",
    "starter_code": "from flask import Flask, jsonify, request\n\napp = Flask(__name__)\n\n# 模拟数据\ntasks = [\n    {'id': 1, 'title': '学习 Python', 'done': False},\n    {'id': 2, 'title': '写代码', 'done': True},\n]\n\n@app.route('/api/tasks', methods=['GET'])\ndef get_tasks():\n    return jsonify({'tasks': tasks})\n\n@app.route('/api/tasks/<int:task_id>', methods=['GET'])\ndef get_task(task_id):\n    task = next((t for t in tasks if t['id'] == task_id), None)\n    if task:\n        return jsonify(task)\n    return jsonify({'error': 'Task not found'}), 404\n\n@app.route('/api/tasks', methods=['POST'])\ndef create_task():\n    # 创建任务\n    pass\n\nif __name__ == '__main__':\n    app.run(debug=True)",
    "solution": "from flask import Flask, jsonify, request\n\napp = Flask(__name__)\n\n# 模拟数据\ntasks = [\n    {'id': 1, 'title': '学习 Python', 'done': False},\n    {'id': 2, 'title': '写代码', 'done': True},\n]\nnext_id = 3\n\n@app.route('/api/tasks', methods=['GET'])\ndef get_tasks():\n    return jsonify({'tasks': tasks})\n\n@app.route('/api/tasks/<int:task_id>', methods=['GET'])\ndef get_task(task_id):\n    task = next((t for t in tasks if t['id'] == task_id), None)\n    if task:\n        return jsonify(task)\n    return jsonify({'error': 'Task not found'}), 404\n\n@app.route('/api/tasks', methods=['POST'])\ndef create_task():\n    global next_id\n    data = request.json\n    task = {\n        'id': next_id,\n        'title': data.get('title', ''),\n        'done': False\n    }\n    tasks.append(task)\n    next_id += 1\n    return jsonify(task), 201\n\nif __name__ == '__main__':\n    app.run(debug=True)",
    "tags": [
      "REST",
      "API"
    ]
  },
  {
    "id": "ex_web_004",
    "module": "web_development",
    "title": "表单处理",
    "difficulty": "medium",
    "points": 15,
    "description": "处理 HTML 表单",
    "starter_code": "from flask import Flask, request, render_template_string\n\napp = Flask(__name__)\n\nhtml = '''\n<!DOCTYPE html>\n<html>\n<body>\n    <form method=\"post\">\n        <label>用户名: <input type=\"text\" name=\"username\"></label><br>\n        <label>密码: <input type=\"password\" name=\"password\"></label><br>\n        <button type=\"submit\">登录</button>\n    </form>\n</body>\n</html>\n'''\n\n@app.route('/login', methods=['GET', 'POST'])\ndef login():\n    if request.method == 'POST':\n        username = request.form['username']\n        password = request.form['password']\n        return f'<h1>Welcome, {username}!</h1>'\n    return render_template_string(html)\n\nif __name__ == '__main__':\n    app.run(debug=True)",
    "solution": "from flask import Flask, request, render_template_string\n\napp = Flask(__name__)\n\nhtml = '''\n<!DOCTYPE html>\n<html>\n<body>\n    <h2>用户登录</h2>\n    <form method=\"post\">\n        <label>用户名: <input type=\"text\" name=\"username\" required></label><br><br>\n        <label>密码: <input type=\"password\" name=\"password\" required></label><br><br>\n        <button type=\"submit\">登录</button>\n    </form>\n    {% if error %}\n    <p style=\"color:red;\">{{ error }}</p>\n    {% endif %}\n</body>\n</html>\n'''\n\nusers = {'admin': '123456', 'user': 'password'}\n\n@app.route('/login', methods=['GET', 'POST'])\ndef login():\n    if request.method == 'POST':\n        username = request.form['username']\n        password = request.form['password']\n        if username in users and users[username] == password:\n            return f'<h1>Welcome, {username}!</h1>'\n        return render_template_string(html, error='用户名或密码错误')\n    return render_template_string(html)\n\nif __name__ == '__main__':\n    app.run(debug=True)",
    "tags": [
      "表单",
      "POST"
    ]
  },
  {
    "id": "ex_web_005",
    "module": "web_development",
    "title": "FastAPI 基础",
    "difficulty": "hard",
    "points": 20,
    "description": "使用 FastAPI 创建 API",
    "starter_code": "from fastapi import FastAPI\nfrom pydantic import BaseModel\n\napp = FastAPI()\n\nclass Item(BaseModel):\n    name: str\n    description: str = None\n    price: float\n    quantity: int\n\nitems = {}\n\n@app.get('/')\ndef read_root():\n    return {'message': 'Welcome to FastAPI'}\n\n@app.get('/items/{item_id}')\ndef read_item(item_id: int):\n    return items.get(item_id, {'error': 'Item not found'})\n\n@app.post('/items')\ndef create_item(item: Item):\n    item_id = len(items) + 1\n    items[item_id] = item.dict()\n    return {'item_id': item_id, 'item': item}\n\n# 运行: uvicorn main:app --reload",
    "solution": "from fastapi import FastAPI, HTTPException\nfrom pydantic import BaseModel\nfrom typing import Optional\n\napp = FastAPI(title='物品管理 API', version='1.0.0')\n\nclass Item(BaseModel):\n    name: str\n    description: Optional[str] = None\n    price: float\n    quantity: int = 0\n\nitems = {}\n\n@app.get('/')\ndef read_root():\n    return {\n        'message': 'Welcome to FastAPI',\n        'docs': '/docs',\n        'items_count': len(items)\n    }\n\n@app.get('/items/{item_id}')\ndef read_item(item_id: int):\n    if item_id not in items:\n        raise HTTPException(status_code=404, detail='Item not found')\n    return items[item_id]\n\n@app.post('/items', status_code=201)\ndef create_item(item: Item):\n    item_id = len(items) + 1\n    items[item_id] = item.dict()\n    return {'item_id': item_id, 'item': item}\n\n@app.get('/items')\ndef list_items():\n    return {'items': items}\n\nif __name__ == '__main__':\n    import uvicorn\n    uvicorn.run(app, host='127.0.0.1', port=8000)",
    "tags": [
      "FastAPI",
      "REST"
    ]
  },
