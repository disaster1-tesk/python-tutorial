    "id": "ex_cv_002",
    "module": "cv_computer_vision",
    "title": "图像滤波",
    "difficulty": "easy",
    "points": 10,
    "description": "使用滤波器处理图像",
    "starter_code": "import cv2\nimport numpy as np\n\n# 创建测试图像\nimage = cv2.imread('test_image.png') if False else np.zeros((100, 100, 3), dtype=np.uint8)\n\n# 添加一些特征\nimage[20:80, 20:80] = 200\n\n# 高斯模糊\nblurred = cv2.GaussianBlur(image, (5, 5), 0)\n\n# 均值模糊\nmean_blur = cv2.blur(image, (5, 5))\n\n# 边缘检测 (Sobel)\ngray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)\nsobelx = cv2.Sobel(gray, cv2.CV_64F, 1, 0, ksize=3)\nsobely = cv2.Sobel(gray, cv2.CV_64F, 0, 1, ksize=3)\n\nprint('原图像素值范围:', image.min(), '-', image.max())\nprint('高斯模糊后:', blurred.min(), '-', blurred.max())",
    "solution": "import cv2\nimport numpy as np\n\n# 创建测试图像\nimage = np.zeros((100, 100, 3), dtype=np.uint8)\nimage[20:80, 20:80] = 200  # 添加一个白色块\n\n# 高斯模糊\nblurred = cv2.GaussianBlur(image, (5, 5), 0)\n\n# 均值模糊\nmean_blur = cv2.blur(image, (5, 5))\n\n# 中值模糊 (对椒盐噪声效果好)\nmedian_blur = cv2.medianBlur(image, 5)\n\n# 边缘检测 (Canny)\ngray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)\nedges = cv2.Canny(gray, 50, 150)\n\nprint('滤波效果演示:')\nprint(f'原图形状: {image.shape}')\nprint(f'高斯模糊后: {blurred.shape}')\nprint(f'边缘检测结果形状: {edges.shape}')\nprint('\\n边缘像素数量:', edges.sum() // 255)",
    "tags": [
      "滤波",
      "模糊"
    ]
  },
  {
    "id": "ex_cv_003",
    "module": "cv_computer_vision",
    "title": "卷积操作",
    "difficulty": "medium",
    "points": 15,
    "description": "手动实现卷积操作",
    "starter_code": "import numpy as np\nimport cv2\n\ndef convolve2d(image, kernel):\n    \"\"\"手动实现2D卷积\"\"\"\n    # 获取图像和核的尺寸\n    ih, iw = image.shape[:2]\n    kh, kw = kernel.shape\n    \n    # 计算输出尺寸\n    oh = ih - kh + 1\n    ow = iw - kw + 1\n    \n    # 初始化输出\n    output = np.zeros((oh, ow))\n    \n    # 遍历并计算\n    # 你的代码\n    \n    return output\n\n# 测试\nimage = np.array([\n    [1, 2, 3, 0, 1],\n    [4, 5, 6, 1, 2],\n    [7, 8, 9, 2, 3],\n    [1, 2, 3, 0, 1],\n    [4, 5, 6, 1, 2]\n], dtype=np.float32)\n\n# 锐化核\nkernel = np.array([\n    [0, -1, 0],\n    [-1, 5, -1],\n    [0, -1, 0]\n], dtype=np.float32)\n\nresult = convolve2d(image, kernel)\nprint('卷积结果:')\nprint(result)",
    "solution": "import numpy as np\nimport cv2\n\ndef convolve2d(image, kernel):\n    \"\"\"手动实现2D卷积\"\"\"\n    ih, iw = image.shape[:2]\n    kh, kw = kernel.shape\n    \n    oh = ih - kh + 1\n    ow = iw - kw + 1\n    \n    output = np.zeros((oh, ow))\n    \n    for i in range(oh):\n        for j in range(ow):\n            output[i, j] = np.sum(image[i:i+kh, j:j+kw] * kernel)\n    \n    return output\n\n# 测试\nimage = np.array([\n    [1, 2, 3, 0, 1],\n    [4, 5, 6, 1, 2],\n    [7, 8, 9, 2, 3],\n    [1, 2, 3, 0, 1],\n    [4, 5, 6, 1, 2]\n], dtype=np.float32)\n\n# 锐化核\nkernel = np.array([\n    [0, -1, 0],\n    [-1, 5, -1],\n    [0, -1, 0]\n], dtype=np.float32)\n\nresult = convolve2d(image, kernel)\nprint('输入图像:')\nprint(image)\nprint('\\n锐化核:')\nprint(kernel)\nprint('\\n卷积结果 (锐化):')\nprint(result)",
    "tags": [
      "卷积",
      "滤波器"
    ]
  },
  {
    "id": "ex_cv_004",
    "module": "cv_computer_vision",
    "title": "图像分割",
    "difficulty": "medium",
    "points": 15,
    "description": "使用阈值分割图像",
    "starter_code": "import cv2\nimport numpy as np\n\n# 创建测试图像\ngray = np.zeros((100, 100), dtype=np.uint8)\ngray[20:80, 20:80] = 200\n\n# 全局阈值分割\n_, binary = cv2.threshold(gray, 127, 255, cv2.THRESH_BINARY)\n\n# 自适应阈值\nadaptive = cv2.adaptiveThreshold(gray, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, \n                                  cv2.THRESH_BINARY, 11, 2)\n\nprint(f'原图唯一值: {np.unique(gray)}')\nprint(f'二值化后唯一值: {np.unique(binary)}')\nprint(f'自适应阈值后唯一值: {np.unique(adaptive)}')",
    "solution": "import cv2\nimport numpy as np\n\n# 创建测试图像\ngray = np.zeros((100, 100), dtype=np.uint8)\ngray[20:80, 20:80] = 200  # 中间一个亮块\n\n# 全局阈值分割\n_, binary = cv2.threshold(gray, 127, 255, cv2.THRESH_BINARY)\n\n# Otsu 自动阈值\n_, otsu = cv2.threshold(gray, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)\n\n# 自适应阈值\nadaptive = cv2.adaptiveThreshold(gray, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, \n                                  cv2.THRESH_BINARY, 11, 2)\n\nprint(f'原图唯一值: {np.unique(gray)}')\nprint(f'二值化(阈值127)唯一值: {np.unique(binary)}')\nprint(f'Otsu自动阈值: {otsu}')\nprint(f'二值化后唯一值: {np.unique(binary)}')\nprint(f'自适应阈值后唯一值: {np.unique(adaptive)}')",
    "tags": [
      "阈值",
      "分割"
    ]
  },
  {
    "id": "ex_cv_005",
    "module": "cv_computer_vision",
    "title": "图像变换",
    "difficulty": "hard",
    "points": 20,
    "description": "实现几何变换",
    "starter_code": "import cv2\nimport numpy as np\n\n# 创建测试图像\nimage = np.zeros((100, 100, 3), dtype=np.uint8)\nimage[30:70, 30:70] = (0, 255, 0)  # 绿色方块\n\n# 缩放\nscale = 2\nh, w = image.shape[:2]\nscaled = cv2.resize(image, (w * scale, h * scale))\n\n# 旋转 45度\ncenter = (w // 2, h // 2)\nangle = 45\nscale = 1.0\nM = cv2.getRotationMatrix2D(center, angle, scale)\nrotated = cv2.warpAffine(image, M, (w, h))\n\n# 平移\nM = np.float32([[1, 0, 20], [0, 1, 10]])  # x方向20，y方向10\ntranslated = cv2.warpAffine(image, M, (w, h))\n\nprint(f'原图尺寸: {image.shape}')\nprint(f'缩放后尺寸: {scaled.shape}')\nprint(f'旋转后尺寸: {rotated.shape}')\nprint(f'平移后尺寸: {translated.shape}')",
    "solution": "import cv2\nimport numpy as np\n\n# 创建测试图像\nimage = np.zeros((100, 100, 3), dtype=np.uint8)\nimage[30:70, 30:70] = (0, 255, 0)  # 绿色方块\n\n# 缩放\nscale = 2\nh, w = image.shape[:2]\nscaled = cv2.resize(image, (w * scale, h * scale))\n\n# 旋转 45度\ncenter = (w // 2, h // 2)\nangle = 45\nscale = 1.0\nM = cv2.getRotationMatrix2D(center, angle, scale)\nrotated = cv2.warpAffine(image, M, (w, h))\n\n# 平移\nM = np.float32([[1, 0, 20], [0, 1, 10]])\ntranslated = cv2.warpAffine(image, M, (w, h))\n\n# 透视变换\npts1 = np.float32([[30, 30], [70, 30], [30, 70], [70, 70]])\npts2 = np.float32([[20, 20], [80, 20], [30, 80], [70, 80]])\nM = cv2.getPerspectiveTransform(pts1, pts2)\nwarped = cv2.warpPerspective(image, M, (w, h))\n\nprint(f'原图尺寸: {image.shape}')\nprint(f'缩放后尺寸: {scaled.shape}')\nprint(f'旋转后尺寸: {rotated.shape}')\nprint(f'平移后尺寸: {translated.shape}')\nprint(f'透视变换后尺寸: {warped.shape}')",
    "tags": [
      "变换",
      "仿射"
    ]
  },
  {
    "id": "ex_unit_001",
    "module": "unit_testing",
    "title": "unittest 基础",
    "difficulty": "easy",
