  {
    "id": "ex_ai_agent_001",
    "module": "ai_agent",
    "title": "AI Agent 基础",
    "difficulty": "medium",
    "points": 15,
    "description": "创建一个简单的 AI Agent 类，包含感知、决策、执行方法",
    "starter_code": "class AIAgent:\n    def __init__(self, name):\n        self.name = name\n        # 初始化\n\n    def perceive(self, environment):\n        # 感知环境\n        pass\n\n    def decide(self):\n        # 决策\n        pass\n\n    def act(self):\n        # 执行\n        pass",
    "solution": "class AIAgent:\n    def __init__(self, name):\n        self.name = name\n        self.state = {}\n        print(f'Agent {self.name} 已创建')\n    \n    def perceive(self, environment):\n        self.state['observation'] = environment\n        print(f'感知: {environment}')\n    \n    def decide(self):\n        obs = self.state.get('observation', '')\n        if 'help' in obs.lower():\n            action = '提供帮助'\n        else:\n            action = '继续观察'\n        self.state['action'] = action\n        return action\n    \n    def act(self):\n        action = self.state.get('action')\n        print(f'执行: {action}')\n        return action\n\n# 测试\tagent = AIAgent('助手')\nagent.perceive('用户需要帮助')\nagent.decide()\nagent.act()",
    "tags": [
      "AI Agent",
      "基础"
    ]
  },
  {
    "id": "ex_ai_agent_002",
    "module": "ai_agent",
    "title": "实现 ReAct 提示",
    "difficulty": "hard",
    "points": 20,
    "description": "模拟 ReAct (Reasoning + Acting) 提示过程",
    "starter_code": "# 模拟 ReAct 循环\ndef react_loop(question, max_steps=3):\n    # 实现推理+行动循环\n    pass",
    "solution": "def react_loop(question, max_steps=3):\n    thoughts = []\n    actions = []\n    observations = []\n    \n    for step in range(max_steps):\n        # 推理\n        if step == 0:\n            thought = f'问题: {question}，我需要先理解问题'\n        else:\n            thought = f'基于上一步结果继续推理'\n        thoughts.append(thought)\n        \n        # 行动（模拟）\n        action = f'搜索相关资料 (步骤{step+1})'\n        actions.append(action)\n        \n        # 观察结果\n        observation = f'找到相关答案片段{step+1}'\n        observations.append(observation)\n        \n        print(f'步骤 {step+1}:')\n        print(f'  推理: {thought}')\n        print(f'  行动: {action}')\n        print(f'  观察: {observation}')\n        print()\n    \n    return '最终答案'\n\n# 测试\nresult = react_loop('Python中如何处理异常？')\nprint(f'最终结果: {result}')",
    "tags": [
      "ReAct",
      "推理"
    ]
  },
  {
    "id": "ex_ai_agent_003",
    "module": "ai_agent",
    "title": "Agent 记忆系统",
    "difficulty": "medium",
    "points": 15,
    "description": "实现 Agent 的短期记忆和长期记忆",
    "starter_code": "class AgentMemory:\n    def __init__(self):\n        self.short_term = []  # 短期记忆\n        self.long_term = {}   # 长期记忆\n    \n    def add_short(self, item):\n        # 添加短期记忆\n        pass\n\n    def add_long(self, key, value):\n        # 添加长期记忆\n        pass\n\n    def recall(self, key):\n        # 回忆\n        pass",
    "solution": "class AgentMemory:\n    def __init__(self, short_capacity=5):\n        self.short_capacity = short_capacity\n        self.short_term = []\n        self.long_term = {}\n    \n    def add_short(self, item):\n        self.short_term.append(item)\n        if len(self.short_term) > self.short_capacity:\n            self.short_term.pop(0)\n        print(f'短期记忆: {self.short_term}')\n    \n    def add_long(self, key, value):\n        self.long_term[key] = value\n        print(f'长期记忆已保存: {key}')\n    \n    def recall(self, key):\n        result = self.long_term.get(key, '未找到')\n        print(f'回忆 {key}: {result}')\n        return result\n\n# 测试\nmemory = AgentMemory()\nmemory.add_short('用户说hello')\nmemory.add_short('用户问Python问题')\nmemory.add_long('Python', '一种编程语言')\nmemory.recall('Python')",
    "tags": [
      "记忆",
      "Agent"
    ]
  },
  {
    "id": "ex_ai_agent_004",
    "module": "ai_agent",
    "title": "CoT 提示实现",
    "difficulty": "medium",
    "points": 15,
    "description": "实现 Chain of Thought 提示，展示推理过程",
    "starter_code": "def chain_of_thought(question):\n    # 实现 CoT\n    pass",
    "solution": "def chain_of_thought(question):\n    steps = []\n    \n    # 步骤1: 理解问题\n    steps.append(f'理解问题: {question}')\n    \n    # 步骤2: 分析问题\n    if '计算' in question or '+' in question or '-' in question:\n        steps.append('识别: 这是一个数学计算问题')\n    elif '什么' in question or '如何' in question:\n        steps.append('识别: 这是一个知识问答问题')\n    \n    # 步骤3: 推理过程\n    steps.append('开始逐步推理...')\n    \n    # 步骤4: 得出结论\n    steps.append('基于以上推理，得出结论')\n    \n    return steps\n\n# 测试\nquestion = '5 + 3 等于几？'\nfor step in chain_of_thought(question):\n    print(step)",
    "tags": [
      "CoT",
      "提示"
    ]
  },
  {
    "id": "ex_ai_agent_005",
    "module": "ai_agent",
    "title": "简单 Agent 工具调用",
    "difficulty": "medium",
    "points": 15,
    "description": "实现 Agent 自主调用工具的能力",
    "starter_code": "class SimpleAgent:\n    def __init__(self):\n        self.tools = {}\n    \n    def register_tool(self, name, func):\n        # 注册工具\n        pass\n    \n    def use_tool(self, tool_name, args):\n        # 使用工具\n        pass",
    "solution": "class SimpleAgent:\n    def __init__(self):\n        self.tools = {}\n    \n    def register_tool(self, name, func, description=''):\n        self.tools[name] = {\n            'func': func,\n            'description': description\n        }\n        print(f'注册工具: {name}')\n    \n    def use_tool(self, tool_name, args):\n        if tool_name not in self.tools:\n            return f'工具不存在: {tool_name}'\n        \n        tool = self.tools[tool_name]\n        result = tool['func'](**args)\n        return result\n    \n    def plan_and_execute(self, goal):\n        # 简单规划\n        print(f'目标: {goal}')\n        \n        if '计算' in goal:\n            return self.use_tool('calculator', {'a': 10, 'b': 5})\n        elif '天气' in goal:\n            return self.use_tool('weather', {'city': '北京'})\n        else:\n            return '无法理解目标'\n\n# 测试\nagent = SimpleAgent()\nagent.register_tool('calculator', lambda a, b: a + b, '计算两个数的和')\nagent.register_tool('weather', lambda city: f'{city} 天气: 晴', '查询天气')\nprint(agent.plan_and_execute('计算10+5'))\nprint(agent.plan_and_execute('查询北京天气'))",
    "tags": [
      "工具调用",
      "Agent"
    ]
  },
  {
    "id": "ex_mcp_protocol_001",
    "module": "mcp_protocol",
    "title": "MCP 工具定义",
    "difficulty": "medium",
    "points": 15,
    "description": "定义一个 MCP 工具的 JSON 结构",
    "starter_code": "# 定义 MCP 工具\ntool = {\n    'name': 'calculate',\n    # 添加描述和参数\n}",
    "solution": "# 定义 MCP 工具\ntool = {\n    'name': 'calculate',\n    'description': '执行简单的数学计算',\n    'inputSchema': {\n        'type': 'object',\n        'properties': {\n            'expression': {\n                'type': 'string',\n                'description': '要计算的数学表达式，如 2+3*4'\n            }\n        },\n        'required': ['expression']\n    }\n}\n\nimport json\nprint(json.dumps(tool, indent=2, ensure_ascii=False))",
    "tags": [
      "MCP",
      "工具"
    ]
  },
  {
    "id": "ex_mcp_protocol_002",
    "module": "mcp_protocol",
    "title": "JSON-RPC 消息构建",
    "difficulty": "medium",
    "points": 15,
    "description": "构建 MCP 协议的 JSON-RPC 消息",
    "starter_code": "def create_jsonrpc_request(method, params=None, req_id=1):\n    # 构建 JSON-RPC 请求\n    pass",
    "solution": "import json\n\ndef create_jsonrpc_request(method, params=None, req_id=1):\n    request = {\n        'jsonrpc': '2.0',\n        'id': req_id,\n        'method': method\n    }\n    if params:\n        request['params'] = params\n    return request\n\n# 测试工具列表请求\nrequest = create_jsonrpc_request('tools/list')\nprint(json.dumps(request, indent=2))\n\n# 测试工具调用请求\nrequest = create_jsonrpc_request(\n    'tools/call',\n    params={'name': 'calculate', 'arguments': {'expression': '2+3'}},\n    req_id=2\n)\nprint(json.dumps(request, indent=2))",
    "tags": [
      "JSON-RPC",
      "MCP"
    ]
  },
  {
    "id": "ex_mcp_protocol_003",
    "module": "mcp_protocol",
    "title": "MCP 资源定义",
    "difficulty": "medium",
    "points": 15,
    "description": "定义 MCP 资源并实现读取",
    "starter_code": "# MCP 资源定义\nresource = {\n    'uri': 'file:///config/app.json',\n    'name': 'app_config',\n    # 添加描述和类型\n}\n\ndef read_resource(uri):\n    # 实现读取\n    pass",
    "solution": "import json\n\n# MCP 资源定义\nresources = [\n    {\n        'uri': 'file:///config/app.json',\n        'name': 'app_config',\n        'description': '应用程序配置文件',\n        'mimeType': 'application/json'\n    },\n    {\n        'uri': 'file:///docs/README.md',\n        'name': 'readme',\n        'description': '项目说明文档',\n        'mimeType': 'text/markdown'\n    }\n]\n\ndef read_resource(uri):\n    if uri == 'file:///config/app.json':\n        return json.dumps({'app': 'Python Tutorial', 'version': '1.0'})\n    return '资源不存在'\n\n# 测试\nfor res in resources:\n    print(f\"资源: {res['name']}\")\n    if res['name'] == 'app_config':\n        print(f\"内容: {read_resource(res['uri'])}\")\n    print()",
    "tags": [
      "MCP",
      "资源"
    ]
