    "id": "ex_database_002",
    "module": "database",
    "title": "SQL 查询练习",
    "difficulty": "easy",
    "points": 10,
    "description": "编写 SQL 查询语句",
    "starter_code": "# 假设有表 students(id, name, score, class_id)\n# 1. 查询所有学生信息\nquery1 = \"\"\"\n\n\"\"\"\n\n# 2. 查询分数大于等于60的学生\nquery2 = \"\"\"\n\n\"\"\"\n\n# 3. 查询每个班级的平均分\nquery3 = \"\"\"\n\n\"\"\"\n\n# 4. 查询最高分学生\nquery4 = \"\"\"\n\n\"\"\"\n\nprint('查询1:', query1.strip())\nprint('查询2:', query2.strip())\nprint('查询3:', query3.strip())\nprint('查询4:', query4.strip())",
    "solution": "# 假设有表 students(id, name, score, class_id)\n# 1. 查询所有学生信息\nquery1 = \"\"\"\nSELECT * FROM students\n\"\"\"\n\n# 2. 查询分数大于等于60的学生\nquery2 = \"\"\"\nSELECT * FROM students WHERE score >= 60\n\"\"\"\n\n# 3. 查询每个班级的平均分\nquery3 = \"\"\"\nSELECT class_id, AVG(score) as avg_score \nFROM students \nGROUP BY class_id\n\"\"\"\n\n# 4. 查询最高分学生\nquery4 = \"\"\"\nSELECT * FROM students \nWHERE score = (SELECT MAX(score) FROM students)\n\"\"\"\n\nprint('查询1:', query1.strip())\nprint('查询2:', query2.strip())\nprint('查询3:', query3.strip())\nprint('查询4:', query4.strip())",
    "tags": [
      "SQL",
      "查询"
    ]
  },
  {
    "id": "ex_database_003",
    "module": "database",
    "title": "使用 SQLAlchemy ORM",
    "difficulty": "medium",
    "points": 15,
    "description": "使用 SQLAlchemy 定义模型并查询",
    "starter_code": "from sqlalchemy import create_engine, Column, Integer, String\nfrom sqlalchemy.ext.declarative import declarative_base\nfrom sqlalchemy.orm import sessionmaker\n\nBase = declarative_base()\n\nclass User(Base):\n    __tablename__ = 'users'\n    \n    id = Column(Integer, primary_key=True)\n    name = Column(String(50))\n    email = Column(String(100))\n\n# 创建引擎和会话\nengine = create_engine('sqlite:///test2.db')\nBase.metadata.create_all(engine)\nSession = sessionmaker(bind=engine)\nsession = Session()\n\n# 添加用户\n# 你的代码\n\n# 查询用户\n# 你的代码\n\nsession.close()",
    "solution": "from sqlalchemy import create_engine, Column, Integer, String\nfrom sqlalchemy.ext.declarative import declarative_base\nfrom sqlalchemy.orm import sessionmaker\n\nBase = declarative_base()\n\nclass User(Base):\n    __tablename__ = 'users'\n    \n    id = Column(Integer, primary_key=True)\n    name = Column(String(50))\n    email = Column(String(100))\n\n# 创建引擎和会话\nengine = create_engine('sqlite:///test2.db')\nBase.metadata.create_all(engine)\nSession = sessionmaker(bind=engine)\nsession = Session()\n\n# 添加用户\nuser1 = User(name='Alice', email='alice@example.com')\nuser2 = User(name='Bob', email='bob@example.com')\nsession.add_all([user1, user2])\nsession.commit()\n\n# 查询用户\nusers = session.query(User).all()\nfor user in users:\n    print(f'{user.id}: {user.name} <{user.email}>')\n\n# 条件查询\nuser = session.query(User).filter_by(name='Alice').first()\nprint(f'找到: {user.name}') if user else print('未找到')\n\nsession.close()",
    "tags": [
      "SQLAlchemy",
      "ORM"
    ]
  },
  {
    "id": "ex_database_004",
    "module": "database",
    "title": "数据库事务处理",
    "difficulty": "medium",
    "points": 15,
    "description": "实现转账事务",
    "starter_code": "import sqlite3\n\nconn = sqlite3.connect('bank.db')\ncursor = conn.cursor()\n\ncursor.execute('CREATE TABLE IF NOT EXISTS accounts (id INTEGER PRIMARY KEY, name TEXT, balance REAL)')\n\ndef transfer(from_id, to_id, amount):\n    # 转账逻辑\n    pass\n\n# 测试转账\n# 你的代码\n\nconn.close()",
    "solution": "import sqlite3\n\nconn = sqlite3.connect('bank.db')\ncursor = conn.cursor()\n\ncursor.execute('CREATE TABLE IF NOT EXISTS accounts (id INTEGER PRIMARY KEY, name TEXT, balance REAL)')\ncursor.execute('DELETE FROM accounts')\ncursor.execute(\"INSERT INTO accounts (id, name, balance) VALUES (1, 'Alice', 1000)\")\ncursor.execute(\"INSERT INTO accounts (id, name, balance) VALUES (2, 'Bob', 500)\")\nconn.commit()\n\ndef transfer(from_id, to_id, amount):\n    try:\n        # 扣除转账人余额\n        cursor.execute('UPDATE accounts SET balance = balance - ? WHERE id = ? AND balance >= ?', \n                      (amount, from_id, amount))\n        if cursor.rowcount == 0:\n            print('余额不足或账户不存在')\n            conn.rollback()\n            return False\n        \n        # 增加收款人余额\n        cursor.execute('UPDATE accounts SET balance = balance + ? WHERE id = ?', \n                      (amount, to_id))\n        \n        conn.commit()\n        print(f'转账成功: {amount}')\n        return True\n    except Exception as e:\n        print(f'转账失败: {e}')\n        conn.rollback()\n        return False\n\n# 测试转账\nprint('转账前:')\ncursor.execute('SELECT * FROM accounts')\nfor row in cursor.fetchall():\n    print(f'  {row}')\n\ntransfer(1, 2, 200)\n\nprint('转账后:')\ncursor.execute('SELECT * FROM accounts')\nfor row in cursor.fetchall():\n    print(f'  {row}')\n\nconn.close()",
    "tags": [
      "事务",
      "转账"
    ]
  },
  {
    "id": "ex_database_005",
    "module": "database",
    "title": "索引优化查询",
    "difficulty": "hard",
    "points": 20,
    "description": "创建索引并测试查询性能",
    "starter_code": "import sqlite3\nimport time\n\nconn = sqlite3.connect('test_perf.db')\ncursor = conn.cursor()\n\n# 创建测试表\ncursor.execute('CREATE TABLE IF NOT EXISTS orders (id, customer_name, amount, order_date)')\n\n# 插入大量测试数据\n# 你的代码\n\n# 无索引查询\n# 你的代码\n\n# 创建索引\n# 你的代码\n\n# 有索引查询\n# 你的代码\n\nconn.close()",
    "solution": "import sqlite3\nimport time\n\nconn = sqlite3.connect('test_perf.db')\ncursor = conn.cursor()\n\n# 创建测试表\ncursor.execute('DROP TABLE IF EXISTS orders')\ncursor.execute('CREATE TABLE orders (id INTEGER PRIMARY KEY, customer_name TEXT, amount REAL, order_date TEXT)')\n\n# 插入大量测试数据\ndata = [(i, f'Customer_{i % 100}', i * 10.5, f'2024-01-{(i % 28) + 1:02d}') for i in range(1, 10001)]\ncursor.executemany('INSERT INTO orders VALUES (?, ?, ?, ?)', data)\nconn.commit()\n\n# 无索引查询\nstart = time.time()\ncursor.execute('SELECT * FROM orders WHERE customer_name = \"Customer_50\"')\nresult = cursor.fetchall()\nprint(f'无索引查询: {len(result)} 条记录, 耗时: {(time.time()-start)*1000:.2f}ms')\n\n# 创建索引\ncursor.execute('CREATE INDEX idx_customer ON orders(customer_name)')\nconn.commit()\n\n# 有索引查询\nstart = time.time()\ncursor.execute('SELECT * FROM orders WHERE customer_name = \"Customer_50\"')\nresult = cursor.fetchall()\nprint(f'有索引查询: {len(result)} 条记录, 耗时: {(time.time()-start)*1000:.2f}ms')\n\nconn.close()",
    "tags": [
      "索引",
      "性能"
    ]
  },
  {
    "id": "ex_design_001",
    "module": "design_patterns",
    "title": "单例模式",
    "difficulty": "easy",
    "points": 10,
    "description": "实现单例模式的数据库连接类",
    "starter_code": "class Database:\n    # 实现单例模式\n    pass\n\n# 测试\ndb1 = Database()\ndb2 = Database()\nprint(f'同一个实例: {db1 is db2}')",
    "solution": "class Database:\n    _instance = None\n    \n    def __new__(cls):\n        if cls._instance is None:\n            cls._instance = super().__new__(cls)\n            cls._instance.connected = False\n        return cls._instance\n    \n    def connect(self):\n        if not self.connected:\n            print('连接数据库...')\n            self.connected = True\n        else:\n            print('已连接')\n    \n    def query(self, sql):\n        print(f'执行SQL: {sql}')\n\n# 测试\ndb1 = Database()\ndb2 = Database()\nprint(f'同一个实例: {db1 is db2}')\n\ndb1.connect()\ndb2.connect()\ndb1.query('SELECT * FROM users')",
    "solution_alt": "class Database:\n    _instance = None\n    \n    def __new__(cls):\n        if cls._instance is None:\n            cls._instance = super().__new__(cls)\n            cls._instance.connected = False\n        return cls._instance\n    \n    def connect(self):\n        if not self.connected:\n            print('连接数据库...')\n            self.connected = True\n        else:\n            print('已连接')\n    \n    def query(self, sql):\n        print(f'执行SQL: {sql}')\n\n# 测试\ndb1 = Database()\ndb2 = Database()\nprint(f'同一个实例: {db1 is db2}')\n\ndb1.connect()\ndb2.connect()\ndb1.query('SELECT * FROM users')",
    "tags": [
      "单例",
      "设计模式"
    ]
  },
  {
    "id": "ex_design_002",
    "module": "design_patterns",
    "title": "工厂模式",
    "difficulty": "easy",
    "points": 10,
    "description": "实现工厂模式创建不同类型的通知",
    "starter_code": "class Notification:\n    def send(self, message):\n        pass\n\nclass EmailNotification(Notification):\n    def send(self, message):\n        print(f'发送邮件: {message}')\n\nclass SMSNotification(Notification):\n    def send(self, message):\n        print(f'发送短信: {message}')\n\nclass PushNotification(Notification):\n    def send(self, message):\n        print(f'推送通知: {message}')\n\nclass NotificationFactory:\n    # 实现工厂方法\n    pass\n\n# 测试\nfactory = NotificationFactory()\nfactory.create('email').send('Hello!')\nfactory.create('sms').send('验证码: 1234')\nfactory.create('push').send('您有新消息')",
    "solution": "class Notification:\n    def send(self, message):\n        pass\n\nclass EmailNotification(Notification):\n    def send(self, message):\n        print(f'发送邮件: {message}')\n\nclass SMSNotification(Notification):\n    def send(self, message):\n        print(f'发送短信: {message}')\n\nclass PushNotification(Notification):\n    def send(self, message):\n        print(f'推送通知: {message}')\n\nclass NotificationFactory:\n    _types = {\n        'email': EmailNotification,\n        'sms': SMSNotification,\n        'push': PushNotification\n    }\n    \n    def create(self, notif_type):\n        cls = self._types.get(notif_type)\n        if cls:\n            return cls()\n        raise ValueError(f'未知通知类型: {notif_type}')\n\n# 测试\nfactory = NotificationFactory()\nfactory.create('email').send('Hello!')\nfactory.create('sms').send('验证码: 1234')\nfactory.create('push').send('您有新消息')",
    "tags": [
      "工厂",
      "设计模式"
    ]
  },
  {
    "id": "ex_design_003",
    "module": "design_patterns",
    "title": "观察者模式",
    "difficulty": "medium",
    "points": 15,
    "description": "实现新闻订阅系统",
    "starter_code": "class Subject:\n    def __init__(self):\n        self.observers = []\n    \n    def attach(self, observer):\n        # 添加观察者\n        pass\n    \n    def detach(self, observer):\n        # 移除观察者\n        pass\n    \n    def notify(self, message):\n        # 通知所有观察者\n        pass\n\nclass Observer:\n    def update(self, message):\n        pass\n\nclass NewsSubscriber(Observer):\n    def __init__(self, name):\n        self.name = name\n    \n    def update(self, message):\n        print(f'{self.name} 收到: {message}')\n\n# 测试\nsubject = Subject()\nsub1 = NewsSubscriber('Alice')\nsub2 = NewsSubscriber('Bob')\nsubject.attach(sub1)\nsubject.attach(sub2)\nsubject.notify('Python 3.12 发布!')\nsubject.detach(sub1)\nsubject.notify('AI 技术新突破')",
    "solution": "class Subject:\n    def __init__(self):\n        self.observers = []\n    \n    def attach(self, observer):\n        if observer not in self.observers:\n            self.observers.append(observer)\n            print(f'{observer.name} 已订阅')\n    \n    def detach(self, observer):\n        if observer in self.observers:\n            self.observers.remove(observer)\n            print(f'{observer.name} 已取消订阅')\n    \n    def notify(self, message):\n        print(f'\\n发布新消息: {message}')\n        for observer in self.observers:\n            observer.update(message)\n\nclass Observer:\n    def update(self, message):\n        pass\n\nclass NewsSubscriber(Observer):\n    def __init__(self, name):\n        self.name = name\n    \n    def update(self, message):\n        print(f'{self.name} 收到: {message}')\n\n# 测试\nsubject = Subject()\nsub1 = NewsSubscriber('Alice')\nsub2 = NewsSubscriber('Bob')\nsubject.attach(sub1)\nsubject.attach(sub2)\nsubject.notify('Python 3.12 发布!')\nsubject.detach(sub1)\nsubject.notify('AI 技术新突破')",
    "tags": [
      "观察者",
      "设计模式"
    ]
  },
  {
    "id": "ex_design_004",
    "module": "design_patterns",
    "title": "装饰器模式",
    "difficulty": "medium",
    "points": 15,
    "description": "实现咖啡订单装饰器",
    "starter_code": "class Coffee:\n    def cost(self):\n        return 10\n    \n    def description(self):\n        return '原味咖啡'\n\nclass CoffeeDecorator:\n    def __init__(self, coffee):\n        self.coffee = coffee\n    \n    def cost(self):\n        return self.coffee.cost()\n    \n    def description(self):\n        return self.coffee.description()\n\n# 实现具体装饰器\nclass Milk(CoffeeDecorator):\n    pass\n\nclass Sugar(CoffeeDecorator):\n    pass\n\nclass Whip(CoffeeDecorator):\n    pass\n\n# 测试\ncoffee = Coffee()\nprint(f'{coffee.description()}: ¥{coffee.cost()}')\n\n# 加牛奶和糖\ncoffee_with_milk = Milk(coffee)\nprint(f'{coffee_with_milk.description()}: ¥{coffee_with_milk.cost()}')\n\n# 加牛奶、糖和奶油\nfancy = Whip(Sugar(Milk(coffee)))\nprint(f'{fancy.description()}: ¥{fancy.cost()}')",
    "solution": "class Coffee:\n    def cost(self):\n        return 10\n    \n    def description(self):\n        return '原味咖啡'\n\nclass CoffeeDecorator:\n    def __init__(self, coffee):\n        self.coffee = coffee\n    \n    def cost(self):\n        return self.coffee.cost()\n    \n    def description(self):\n        return self.coffee.description()\n\nclass Milk(CoffeeDecorator):\n    def cost(self):\n        return self.coffee.cost() + 3\n    \n    def description(self):\n        return self.coffee.description() + ' + 牛奶'\n\nclass Sugar(CoffeeDecorator):\n    def cost(self):\n        return self.coffee.cost() + 2\n    \n    def description(self):\n        return self.coffee.description() + ' + 糖'\n\nclass Whip(CoffeeDecorator):\n    def cost(self):\n        return self.coffee.cost() + 5\n    \n    def description(self):\n        return self.coffee.description() + ' + 奶油'\n\n# 测试\ncoffee = Coffee()\nprint(f'{coffee.description()}: ¥{coffee.cost()}')\n\ncoffee_with_milk = Milk(coffee)\nprint(f'{coffee_with_milk.description()}: ¥{coffee_with_milk.cost()}')\n\nfancy = Whip(Sugar(Milk(coffee)))\nprint(f'{fancy.description()}: ¥{fancy.cost()}')",
    "tags": [
      "装饰器",
      "设计模式"
    ]
  },
  {
    "id": "ex_design_005",
    "module": "design_patterns",
    "title": "策略模式",
    "difficulty": "hard",
    "points": 20,
    "description": "实现支付策略",
    "starter_code": "class PaymentStrategy:\n    def pay(self, amount):\n        pass\n\nclass CreditCardPayment(PaymentStrategy):\n    def __init__(self, card_number):\n        self.card_number = card_number\n    \n    def pay(self, amount):\n        print(f'信用卡 {self.card_number[-4:]} 支付 ¥{amount}')\n\nclass AlipayPayment(PaymentStrategy):\n    def pay(self, amount):\n        print(f'支付宝支付 ¥{amount}')\n\nclass WechatPayment(PaymentStrategy):\n    def pay(self, amount):\n        print(f'微信支付 ¥{amount}')\n\nclass ShoppingCart:\n    def __init__(self):\n        self.items = []\n    \n    def add_item(self, item, price):\n        self.items.append((item, price))\n    \n    def set_payment(self, payment_strategy):\n        # 设置支付策略\n        pass\n    \n    def checkout(self):\n        # 计算总价并支付\n        pass\n\n# 测试\ncart = ShoppingCart()\ncart.add_item('Python书籍', 89)\ncart.add_item('键盘', 199)\n\ncart.set_payment(CreditCardPayment('1234567890123456'))\ncart.checkout()",
    "solution": "class PaymentStrategy:\n    def pay(self, amount):\n        pass\n\nclass CreditCardPayment(PaymentStrategy):\n    def __init__(self, card_number):\n        self.card_number = card_number\n    \n    def pay(self, amount):\n        print(f'信用卡 {self.card_number[-4:]} 支付 ¥{amount}')\n\nclass AlipayPayment(PaymentStrategy):\n    def pay(self, amount):\n        print(f'支付宝支付 ¥{amount}')\n\nclass WechatPayment(PaymentStrategy):\n    def pay(self, amount):\n        print(f'微信支付 ¥{amount}')\n\nclass ShoppingCart:\n    def __init__(self):\n        self.items = []\n        self.payment_strategy = None\n    \n    def add_item(self, item, price):\n        self.items.append((item, price))\n    \n    def set_payment(self, payment_strategy):\n        self.payment_strategy = payment_strategy\n    \n    def checkout(self):\n        total = sum(price for _, price in self.items)\n        print(f'商品: {[item for item, _ in self.items]}')\n        print(f'总计: ¥{total}')\n        if self.payment_strategy:\n            self.payment_strategy.pay(total)\n\n# 测试\ncart = ShoppingCart()\ncart.add_item('Python书籍', 89)\ncart.add_item('键盘', 199)\n\ncart.set_payment(CreditCardPayment('1234567890123456'))\ncart.checkout()\n\nprint()\ncart.set_payment(AlipayPayment())\ncart.checkout()",
