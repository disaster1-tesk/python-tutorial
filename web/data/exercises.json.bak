    "id": "ex_nlp_005",
    "module": "nlp_and_llm",
    "title": "文本嵌入",
    "difficulty": "hard",
    "points": 20,
    "description": "获取文本的向量表示",
    "starter_code": "from sentence_transformers import SentenceTransformer\n\n# 加载模型\nmodel = SentenceTransformer('all-MiniLM-L6-v2')\n\nsentences = [\n    \"The cat is sleeping on the couch\",\n    \"A dog is playing in the garden\",\n    \"The weather is nice today\"\n]\n\n# 获取嵌入\n# 你的代码\n\n# 计算相似度\nfrom sklearn.metrics.pairwise import cosine_similarity\nsimilarity = cosine_similarity(embeddings)\nprint('\\n句子相似度矩阵:')\nprint(similarity)",
    "solution": "from sentence_transformers import SentenceTransformer\nfrom sklearn.metrics.pairwise import cosine_similarity\nimport numpy as np\n\ntry:\n    # 加载模型\n    model = SentenceTransformer('all-MiniLM-L6-v2')\n    \n    sentences = [\n        \"The cat is sleeping on the couch\",\n        \"A dog is playing in the garden\",\n        \"The weather is nice today\"\n    ]\n    \n    # 获取嵌入\n    embeddings = model.encode(sentences)\n    \n    print(f'嵌入维度: {embeddings.shape}')\n    print(f'句子数: {len(sentences)}')\n    \n    # 计算相似度\n    similarity = cosine_similarity(embeddings)\n    print('\\n句子相似度矩阵:')\n    for i, s1 in enumerate(sentences):\n        for j, s2 in enumerate(sentences):\n            if i < j:\n                print(f'  \"{s1[:20]}...\" vs \"{s2[:20]}...\": {similarity[i][j]:.4f}')\n                \nexcept Exception as e:\n    print('演示 - 句子嵌入概念:')\n    print('cat vs dog: 0.85 (语义相似)')\n    print('cat vs weather: 0.12 (语义不相似)')",
    "tags": [
      "嵌入",
      "相似度"
    ]
  },
