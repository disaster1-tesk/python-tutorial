  {
    "id": "ex_adv_004",
    "module": "advanced_features",
    "title": "迭代器",
    "difficulty": "medium",
    "points": 15,
    "description": "创建自定义迭代器",
    "starter_code": "class Counter:\n    # 创建迭代器",
    "solution": "class Counter:\n    def __init__(self, limit):\n        self.limit = limit\n        self.current = 0\n    \n    def __iter__(self):\n        return self\n    \n    def __next__(self):\n        if self.current < self.limit:\n            self.current += 1\n            return self.current\n        raise StopIteration\n\nfor i in Counter(3):\n    print(i)",
    "tags": [
      "迭代器",
      "iter"
    ]
  },
  {
    "id": "ex_adv_005",
    "module": "advanced_features",
    "title": "浅拷贝与深拷贝",
    "difficulty": "medium",
    "points": 15,
    "description": "理解深浅拷贝区别",
    "starter_code": "import copy\n\noriginal = [[1, 2], [3, 4]]\n# 浅拷贝",
    "solution": "import copy\n\noriginal = [[1, 2], [3, 4]]\nshallow = copy.copy(original)\ndeep = copy.deepcopy(original)\n\noriginal[0][0] = 99\nprint(shallow[0][0])  # 99 - 浅拷贝受影响\nprint(deep[0][0])     # 1 - 深拷贝不受影响",
